{
  "name": "codesage",
  "displayName": "CodeSage",
  "description": "函数调用链与全局变量数据流分析工具 — 基于 Clang LibTooling",
  "version": "1.0.0",
  "publisher": "codesage",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Programming Languages", "Visualization"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeSage.parseProject",
        "title": "CodeSage: 开始解析",
        "category": "CodeSage"
      },
      {
        "command": "codeSage.searchFunction",
        "title": "CodeSage: 搜索函数",
        "category": "CodeSage"
      },
      {
        "command": "codeSage.searchVariable",
        "title": "CodeSage: 搜索全局变量",
        "category": "CodeSage"
      },
      {
        "command": "codeSage.openGraph",
        "title": "CodeSage: 打开图谱视图",
        "category": "CodeSage"
      },
      {
        "command": "codeSage.configureProject",
        "title": "CodeSage: 配置项目",
        "category": "CodeSage"
      },
      {
        "command": "codeSage.cancelParse",
        "title": "CodeSage: 取消解析",
        "category": "CodeSage"
      },
      {
        "command": "codeSage.selectCoreModules",
        "title": "CodeSage: 选择核心模块",
        "category": "CodeSage"
      }
    ],
    "configuration": {
      "title": "CodeSage",
      "properties": {
        "codeSage.analyzerPath": {
          "type": "string",
          "default": "",
          "description": "code-sage 可执行文件路径（留空则自动查找 analyzer/build/code-sage）"
        },
        "codeSage.compileDbPath": {
          "type": "string",
          "default": "",
          "description": "compile_commands.json 路径（留空则使用工作区根目录下的文件）"
        },
        "codeSage.coreModules": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "核心模块列表（推荐使用命令面板 CodeSage: 选择核心模块 进行设置）"
        },
        "codeSage.systemReplace": {
          "type": "boolean",
          "default": false,
          "description": "自动将 -I 替换为 --isystem"
        },
        "codeSage.backendPort": {
          "type": "number",
          "default": 9527,
          "description": "后端服务端口"
        },
        "codeSage.versionLabel": {
          "type": "string",
          "default": "default",
          "description": "当前分析的代码版本标签（如 v5.10、ohos-3.2），不同版本使用独立数据库"
        },
        "codeSage.parseJobs": {
          "type": "number",
          "default": 0,
          "description": "并行解析线程数（0 = 自动，使用 CPU核心数-2；最小为 1）"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesage-explorer",
          "title": "CodeSage",
          "icon": "$(search)"
        }
      ]
    },
    "views": {
      "codesage-explorer": [
        {
          "id": "codesage.searchResults",
          "name": "搜索结果"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && cd webview && npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
