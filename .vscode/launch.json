{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "运行扩展 (Extension Host)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/dist/**/*.js"
      ],
      "sourceMaps": true,
      "preLaunchTask": "build-all",
      "env": {
        "CODESAGE_ANALYZER_PATH": "${workspaceFolder}/analyzer/build/code-sage"
      }
    },
    {
      "name": "运行扩展 (无预编译)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/dist/**/*.js"
      ],
      "sourceMaps": true,
      "env": {
        "CODESAGE_ANALYZER_PATH": "${workspaceFolder}/analyzer/build/code-sage"
      }
    },
    {
      "name": "调试后端服务",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/dist/index.js",
      "outFiles": [
        "${workspaceFolder}/backend/dist/**/*.js"
      ],
      "sourceMaps": true,
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "CODESAGE_ANALYZER_PATH": "${workspaceFolder}/analyzer/build/code-sage",
        "CODESAGE_DB_PATH": "${workspaceFolder}/.codesage_db",
        "CODESAGE_PORT": "9527"
      },
      "preLaunchTask": "build-backend"
    },
    {
      "name": "扩展测试",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--extensionTestsPath=${workspaceFolder}/extension/dist/test"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/dist/**/*.js"
      ],
      "sourceMaps": true,
      "preLaunchTask": "build-extension"
    }
  ],
  "compounds": [
    {
      "name": "扩展 + 后端 (全栈调试)",
      "configurations": [
        "运行扩展 (Extension Host)",
        "调试后端服务"
      ]
    }
  ]
}
