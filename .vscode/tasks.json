{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-extension",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "watch-extension",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "build-webview",
      "type": "shell",
      "command": "npx vite build",
      "options": {
        "cwd": "${workspaceFolder}/extension/webview"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build-backend",
      "type": "shell",
      "command": "npx tsc",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build-all",
      "dependsOn": [
        "build-extension",
        "build-webview",
        "build-backend"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "build-cpp",
      "type": "shell",
      "command": "cmake --build build -j$(sysctl -n hw.ncpu)",
      "options": {
        "cwd": "${workspaceFolder}/analyzer"
      },
      "group": "build",
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": ["relative", "${workspaceFolder}/analyzer"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}
